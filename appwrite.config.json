{
  "projectId": "${EXPO_PUBLIC_APPWRITE_PROJECT_ID}",
  "endpoint": "${EXPO_PUBLIC_APPWRITE_ENDPOINT}",
  "functions": [
    {
      "$id": "place-order",
      "name": "Place Cash on Delivery Order",
      "runtime": "node-22",
      "path": "functions/place-order",
      "entrypoint": "src/main.js",
      "commands": "npm install --omit=dev",
      "execute": ["users"],
      "events": [],
      "schedule": "",
      "timeout": 30,
      "enabled": true,
      "logging": true,
      "ignore": ["node_modules", ".git", "test"],
      "scopes": ["documents.read", "documents.write"],
      "vars": [
        {
          "$id": "grovi-database-id",
          "key": "GROVI_DATABASE_ID",
          "value": "grovi_staging"
        }
      ]
    }
  ]
}
